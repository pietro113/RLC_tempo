import numpy as np
import matplotlib.pyplot as plt

t, ch1, ch2 = np.loadtxt(
    "TEK00001.CSV",
    delimiter=",",
    skiprows=16,
    unpack=True
)

# plot completo
plt.figure(figsize=(10, 5))
plt.plot(t, ch1, label="CH1")
plt.plot(t, ch2, label="CH2")
plt.xlabel("Tempo [s]")
plt.ylabel("Tensione [V]")
plt.title("Segnale completo dal CSV")
plt.legend()
plt.grid(True)
plt.show()